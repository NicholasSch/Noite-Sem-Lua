  m_Script: {fileID: 11500000, guid: 9a48319fb844ee847afe5ece4b9a4c4f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  lines:
  - "<color=#531182>Lucas:</color> Ol\xE1? Senhora? Eu sou o Lucas, neto do Dante."
  - "<color=#A2EA30>Dona Curi\xF3:</color> Cuidado onde pisa, garoto. A terra do
    seu av\xF4 tem mem\xF3ria longa para d\xEDvidas."
  - "<color=#531182>Lucas:</color> D\xEDvidas? Meu av\xF4 era um homem simples."
  - "<color=#A2EA30>Dona Curi\xF3:</color> Neste ch\xE3o, nada \xE9 simples."
