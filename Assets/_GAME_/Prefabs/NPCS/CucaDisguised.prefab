    - target: {fileID: 2788065578304300599, guid: 65d75c2f3c24c5d4ead76cf5396048bf, type: 3}
      propertyPath: 'lines.Array.data[1]'
      value: "<color=#A2EA30>Dona Curi\xF3:</color> Cuidado onde pisa, garoto. A
        terra do seu av\xF4 tem mem\xF3ria longa para d\xEDvidas."
      objectReference: {fileID: 0}
    - target: {fileID: 2788065578304300599, guid: 65d75c2f3c24c5d4ead76cf5396048bf, type: 3}
      propertyPath: 'lines.Array.data[2]'
      value: "<color=#531182>Lucas:</color> D\xEDvidas? Meu av\xF4 era um homem simples."
      objectReference: {fileID: 0}
    - target: {fileID: 2788065578304300599, guid: 65d75c2f3c24c5d4ead76cf5396048bf, type: 3}
      propertyPath: 'lines.Array.data[3]'
      value: "<color=#A2EA30>Dona Curi\xF3:</color> Neste ch\xE3o, nada \xE9 simples."
      objectReference: {fileID: 0}
